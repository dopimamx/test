# Dopima — Apache .htaccess (v2.0)
# Última actualización: 2026-04-24

# 1. Desactivar listado de directorios
Options -Indexes
IndexIgnore *

# 2. Bloquear acceso a archivos sensibles
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<FilesMatch "\.(bak|log|sql|md|json|yml|yaml|lock|env|config|ini|py)$">
  Require all denied
</FilesMatch>

# 3. Proteger carpetas internas
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Bloquear acceso directo a uploads/raw assets
  RewriteRule ^uploads/.*$ - [F,L]
  RewriteRule ^build/.*$ - [F,L]

  # 4. Forzar HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 5. Forzar non-www → www o viceversa (descomenta el que apliques)
  # Forzar SIN www (recomendado para dopima.com):
  RewriteCond %{HTTP_HOST} ^www\.dopima\.com$ [NC]
  RewriteRule ^(.*)$ https://dopima.com/$1 [L,R=301]

  # 6. Redirects 301 para enlaces antiguos (preservar SEO)
  # Antes el landing era "Landing Page.html" y "Landing_Page.html"
  RewriteRule ^Landing[\s_]Page\.html$ / [R=301,L,NC]
  RewriteRule ^Landing%20Page\.html$ / [R=301,L,NC]

  # 7. Trailing slash consistente para directorios
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]
</IfModule>

# 8. HTTP security headers
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), interest-cohort=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header set X-XSS-Protection "1; mode=block"

  # Content Security Policy - permisivo para fonts/wa.link, restrictivo para scripts
  # Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'"

  # Permitir indexación a IA
  <FilesMatch "\.(html|htm)$">
    Header set X-Robots-Tag "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
  </FilesMatch>
</IfModule>

# 9. Cache estático (rendimiento + SEO)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
  ExpiresByType text/plain "access plus 1 day"

  # Fonts (Google Fonts - aunque vienen externos)
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# 10. Compresión Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/xml text/xml text/plain image/svg+xml application/json application/ld+json application/rss+xml application/atom+xml
</IfModule>

# 11. MIME types correctos (algunos hostings los tienen mal)
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType application/ld+json .jsonld
  AddType image/svg+xml .svg .svgz
  AddType text/cache-manifest .appcache .manifest
  AddType text/plain .txt
</IfModule>

# 12. Cors para fonts (si las sirves desde tu propio dominio)
<IfModule mod_headers.c>
  <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

# 13. ETags off (mejor cache control con headers explícitos)
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
